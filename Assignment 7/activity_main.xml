<GridLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:columnCount="2"
    android:rowCount="4"
    android:padding="16dp"
    android:alignmentMode="alignMargins">

    <Button android:id="@+id/btnToggle" android:text="Toggle/Checkbox" android:layout_columnWeight="1" />
    <Button android:id="@+id/btnRadio" android:text="Radio/Spinner" android:layout_columnWeight="1" />
    <Button android:id="@+id/btnProgress" android:text="Progress Bars" android:layout_columnWeight="1" />
    <Button android:id="@+id/btnRating" android:text="Rating/Alert" android:layout_columnWeight="1" />

</GridLayout>