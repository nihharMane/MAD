<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:id="@+id/main"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Internal Storage Demo"
            android:textColor="@color/primary_teal"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Practical Lab Experiment"
            android:textColor="@color/text_main"
            android:alpha="0.7"
            android:layout_marginBottom="32dp"/>

        <!-- Input Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enter Data to Save"
            android:textStyle="bold"
            android:textColor="@color/text_main"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/editTextData"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Type something here..."
            android:inputType="textLongMessage"
            android:background="@drawable/rounded_edittext"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:elevation="2dp"/>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/buttonSave"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Save to Storage"
                android:backgroundTint="@color/primary_teal"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/buttonRead"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Read from Storage"
                android:backgroundTint="@color/secondary_blue"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- Display Section -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDDDDD"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stored Data Content:"
            android:textStyle="bold"
            android:textColor="@color/text_main"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/textViewDisplay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="100dp"
            android:text="[No data read yet]"
            android:background="@drawable/rounded_display"
            android:padding="16dp"
            android:textColor="@color/text_main"
            android:layout_marginBottom="32dp"
            android:elevation="2dp"/>

        <!-- Bonus: Clear Button -->
        <Button
            android:id="@+id/buttonClear"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Clear Storage"
            android:backgroundTint="@color/accent_error"
            style="@style/Widget.Material3.Button.TextButton"/>

    </LinearLayout>
</ScrollView>